# ──────────────────────────────────────────────
# OmniCommerce 환경변수 (.env.example)
# 부트스트랩 허용 목록 (CLAUDE.md §9.2) 항목만 여기에 둡니다.
# 그 외 런타임 설정은 DB app_settings 테이블에서 관리합니다.
# ──────────────────────────────────────────────

# ── 인프라 접속 ──
DATABASE_URL=postgresql+asyncpg://omni_user:omni_secure_2026!@localhost:5432/omni_commerce
DATABASE_URL_SYNC=postgresql+psycopg2://omni_user:omni_secure_2026!@localhost:5432/omni_commerce
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ── 암호학적 시크릿 ──
JWT_SIGNING_SECRET=change-me-in-production-use-openssl-rand-base64-64
SESSION_SECRET=change-me-session-secret
FERNET_KEY=change-me-fernet-key-base64
CAFE24_WEBHOOK_SECRET=           # 카페24 웹훅 HMAC 서명 검증용 (비워두면 검증 생략)

# ── 부팅 런타임 ──
ENV=dev
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=DEBUG

# ── 관찰성 ──
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── 최초 관리자 시드 (첫 부팅에서만 사용) ──
BOOTSTRAP_ADMIN_EMAIL=admin@omnicommerce.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
